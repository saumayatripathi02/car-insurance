# Backend Environment Variables
# Copy this file to .env and fill in the values

# Core Configuration
NODE_ENV=production
PORT=5000
JWT_SECRET=GENERATE_STRONG_SECRET_KEY_AT_LEAST_32_CHARS
JWT_EXPIRY=24h

# Database
MONGODB_URI=mongodb://localhost:27017/car-insurance

# CORS - Restrict to your actual domain
ALLOWED_ORIGINS="*"

# Email Configuration (Gmail Example)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# OTP Configuration
OTP_EXPIRY=300000

# Payment Processing (Stripe)
STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_key
STRIPE_SECRET_KEY=sk_test_or_sk_live_key

# SendGrid (Alternative email service)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Security: Set in production
SECURE_COOKIES=true
HTTPS_ONLY=true
